# Copie para .env e preencha (local). Em produção, use Railway Variables.

# Porta do servidor (Railway define automaticamente)
PORT=3000

# Segredo das sessões — gere um valor aleatório longo
SESSION_SECRET=troque-por-um-segredo-aleatorio-longo

# Admin inicial (criado só no primeiro boot, se não existir nenhum usuário)
ADMIN_LOGIN=admin
ADMIN_SENHA=admin123

# Dias de antecedência para o alerta de inauguração (padrão: 15)
ALERTA_DIAS_INAUGURACAO=15

# Pasta dos arquivos JSON (padrão: ./data). No Railway, aponte para o Volume.
# DATA_DIR=/data
